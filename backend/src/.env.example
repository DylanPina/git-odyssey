DATABASE_URL=postgresql://postgres:postgres@db:5432/gitodyssey
DATABASE_SSLMODE=disable
FRONTEND_URL=http://localhost:5173
SECRET_KEY=replace-me
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
GITHUB_APP_NAME=your-github-app-slug
OPENAI_API_KEY=your-openai-api-key
GOOGLE_API_KEY=your-google-ai-api-key
# Optional when loading secrets from AWS Secrets Manager instead of storing them locally:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_SESSION_EXPIRATION=
# SECRETS_PREFIX=git-odyssey-prod
